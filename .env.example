# ─── Database ───
DATABASE_URL=postgresql+asyncpg://platform:platform_secret@postgres:5432/ai_platform
DATABASE_URL_SYNC=postgresql://platform:platform_secret@postgres:5432/ai_platform
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform_secret
POSTGRES_DB=ai_platform

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── JWT ───
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=ai-platform
JWT_AUDIENCE=ai-platform-api

# ─── MinIO (S3-compatible) ───
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-platform-files
MINIO_USE_SSL=false

# ─── Qdrant ───
QDRANT_URL=http://qdrant:6333

# ─── ClamAV ───
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ─── OpenAI ───
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Service URLs (inter-service communication) ───
AUTH_SERVICE_URL=http://auth_service:8001
FILE_SERVICE_URL=http://file_service:8002
RAG_WORKER_URL=http://rag_worker:8003
LLM_SERVICE_URL=http://llm_service:8004
MONITORING_SERVICE_URL=http://monitoring_service:8005

# ─── Embedding ───
EMBEDDING_MODEL=all-MiniLM-L6-v2
QDRANT_COLLECTION=documents

# ─── Internal ───
INTERNAL_SERVICE_TOKEN=CHANGE_ME_INTERNAL_SECRET
SYSTEM_VERSION=0.1.0
